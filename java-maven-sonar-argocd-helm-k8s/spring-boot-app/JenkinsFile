pipeline{
  agent{
    docker {
      image 'abhishekf5/maven-abhishek-docker-agent:v1'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
    }
  }

  stages{
    stage("checkout"){
      steps{
        sh 'echo passed'
        //checkout scmGit(branches: [[name: '*/main']], extensions: [], userRemoteConfigs: [[url: 'https://github.com/SivaSuribabu/Jenkins-Zero-To-Hero.git/java-']])
      }
    }
    stage('Build&test'){
      steps{
        sh 'ls -ltr'
        sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && maven clean package'
      }
    }
    
  }
}